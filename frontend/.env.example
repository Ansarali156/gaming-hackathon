# ==========================================
# NEXT.JS FRONTEND - ENVIRONMENT VARIABLES
# ==========================================

# --- 1. CORE APPLICATION ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key"

# --- 2. DATABASE (RENDER POSTGRES) ---
DATABASE_URL="postgresql://user:password@host/dbname"

# --- 3. PAYMENTS (RAZORPAY) ---
# Use your Razorpay test or live keys here
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_secret_..."

# --- 5. SUN FORWARDING (LOCAL) ---
# Shared symmetric key used to encrypt and authenticate payloads sent to SUN
SUN_SHARED_KEY="replace_with_secure_random_key"
# Full URL to the SUN endpoint that will receive the encrypted JSON
SUN_ENDPOINT_URL="http://localhost/sun/public/gaminghackathon/create-order.php"

# --- 4. MAILER (NODEMAILER / GMAIL) ---
# You need an App Password from Google Account Security (NOT your normal password)
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
