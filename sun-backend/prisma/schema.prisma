generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum LedgerStatus {
  CREATED
  ATTEMPTED
  CAPTURED
  FAILED
}

model PaymentLedger {
  id                  String       @id @default(cuid())
  sourceTransactionId String
  payerName           String?
  payerEmail          String?
  payerPhone          String?
  razorpayOrderId     String?
  razorpayPaymentId   String?
  status              LedgerStatus @default(CREATED)
  rawPayload          Json?
  createdAt           DateTime     @default(now())

  @@map("payment_ledger")
}
