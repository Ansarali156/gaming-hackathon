# ==========================================
# NODE.JS BACKEND - ENVIRONMENT VARIABLES
# ==========================================

# --- 1. CORE APPLICATION ---
BACKEND_PORT=4000
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"
JWT_SECRET="your-jwt-secret-key"

# --- 2. DATABASE (RENDER POSTGRES) ---
DATABASE_URL="postgresql://user:password@host/dbname"

# --- 3. PAYMENTS (RAZORPAY) ---
# Use the same keys as the frontend
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_secret_..."

# --- 4. MAILER (NODEMAILER / GMAIL) ---
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="noreply@incuxai.com"

# --- 5. DISCORD OAUTH (OPTIONAL) ---
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
