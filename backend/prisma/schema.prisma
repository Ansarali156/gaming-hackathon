generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PARTICIPANT
  ADMIN
  SPONSOR
  MENTOR
  JUDGE
}

enum Category {
  STUDENT
  IT_PROFESSIONAL
  STARTUP
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TeamStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  mobile        String?
  college       String?
  linkedin      String?
  role          Role      @default(PARTICIPANT)
  image         String?
  discordId     String?
  discordJoined Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  teamMembers   TeamMember[]
  tickets       Ticket[]
  referralsSent Referral[] @relation("Referrer")
  referralsReceived Referral[] @relation("Referred")
  ambassador    CampusAmbassador?

  @@index([email])
  @@index([role])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Team {
  id              String     @id @default(cuid())
  teamId          String     @unique
  name            String
  category        Category
  projectTheme    String?
  techStack       String?
  projectTitle    String?
  projectDesc     String?
  githubLink      String?
  demoVideo       String?
  pptLink         String?
  status          TeamStatus @default(PENDING)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  members         TeamMember[]
  payment         Payment?
  submission      Submission?

  @@index([teamId])
  @@index([category])
  @@index([status])
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("MEMBER")
  skills    String?
  position  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

model Payment {
  id              String        @id @default(cuid())
  teamId          String        @unique
  amount          Float
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  razorpayOrderId String?
  razorpayPaymentId String?
  razorpaySignature String?
  gstInvoice      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  team            Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([status])
}

model Submission {
  id          String   @id @default(cuid())
  teamId      String   @unique
  pptLink     String?
  demoVideo   String?
  githubLink  String?
  apkLink     String?
  submittedAt DateTime @default(now())

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model Sponsor {
  id          String   @id @default(cuid())
  name        String
  tier        String
  logo        String?
  website     String?
  description String?
  contact     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tier])
  @@index([isActive])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  message     String
  visibility  String   @default("ALL")
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([visibility])
  @@index([isPinned])
}

model Ticket {
  id          String       @id @default(cuid())
  userId      String
  subject     String
  message     String
  status      TicketStatus @default(OPEN)
  category    String
  assignedTo  String?
  response    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([category])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String
  points      Int      @default(10)
  createdAt   DateTime @default(now())

  referrer    User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred    User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
  @@index([referrerId])
}

model CampusAmbassador {
  id            String   @id @default(cuid())
  userId        String   @unique
  college       String
  referralCode  String   @unique
  points        Int      @default(0)
  referrals     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventStats {
  id              String   @id @default(cuid())
  key             String   @unique
  value           Int      @default(0)
  label           String
  updatedAt       DateTime @updatedAt

  @@index([key])
}

model SponsorshipInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  company   String?
  message   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}
